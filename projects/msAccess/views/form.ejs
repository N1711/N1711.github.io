<!DOCTYPE html>
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title>NOC Login Form</title>
        <meta name="description" content="">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
        <link rel="stylesheet" href="/navs.css">
    </head>
    <body>
        <ul>
            <% if (userLevel == 1) { %>
            <li><a href="/adm/userMgm"><i class="fa fa-users" aria-hidden="true"></i>User Management</a></li>
            <% } %>
            <li><a class="active" href="/"><i class="fa fa-sticky-note-o" aria-hidden="true"></i> Call Log Form</a></li>
            <li><a href="/dash"><i class="fa fa-bar-chart" aria-hidden="true"></i> Dashboard</a></li>
            <li><a href="/profile">My Profile</a></li>
            <li><a href="/signOut">Sign Out</a></li>
            <li style="float:right"><a href="/profile"><i class="fa fa-user-circle" aria-hidden="true"></i> <%= name %></a><li>
        </ul>
        <div align="center" class="formLog">
            <form method="POST" name="SiebelForm" action="/new">
                <div align="center"><label class="formTitle">Call Log Form</label></div><br>
                <input type="date" id="date" name="date" placeholder="Date" required><br><br>
                <input type="text" id="reference" name="reference" placeholder="Call Reference" required><br><br>
                <select id="syslogged" name="syslogged" required>
                    <option value="" disabled selected>(Logged Via)</option>
                    <option value="Siebel">Siebel</option>
                    <option value="Salesforce">Salesforce</option>
                </select><br><br>
                <input type="text" id="engineer" name="engineer" value="<%= user %>"><br><br>
                <select id="connection" name="connection" required>
                    <option value="" disabled selected>(Remote Connection?)</option>
                    <option value=true>Yes</option>
                    <option value=false>No</option>
                </select><br><br>
                <select id="status" name="status" required>
                    <option value="" disabled selected>(Closed Status)</option>
                    <option value="Remote Resolution">Remote Resolution</option>
                    <option value="Passed to Call Out">Passed To Call Out</option>
                </select><br><br>
                <select id="generated" name="generated" required>
                    <option value="" disabled selected>(Generated By)</option>
                    <option value="Email">Email</option>
                    <option value="Phone">Phone</option>
                    <option value="Bureau">Bureau</option>
                </select><br><br>
                <select id="calltype" name="calltype" required>
                    <option value="" disabled selected>(Call Type)</option>
                    <option value="963 Alarm Server">963 Alarm Server</option>
                    <option value="Action Management">Action Management</option>
                    <option value="BT Server">BT Server</option>
                    <option value="Field Service">Field Service</option>
                    <option value="IQ Review/Oracle">IQ Review/Oracle</option>
                    <option value="SET Metering">SET Metering</option>
                    <option value="TEC Support">TEC Support</option>
                    <option value="TEM">TEM</option>
                    <option value="Trend Connect">Trend Connect</option>
                    <option value="IQVision Alarm Server">IQVision Alarm Server</option>
                </select><br><br>
                <select id="connectiontype" name="connectiontype" required>
                    <option value="" disabled selected>(Connection Type)</option>
                    <option value="IP">IP</option>
                    <option value="Modem">Modem</option>
                    <option value="Trend Connect">Trend Connect</option>
                    <option value="No Connection">No Connection</option>
                    <option value="RDP">RDP</option>
                    <option value="Cloud">Cloud</option>
                </select><br><br>
                <select id="region" name="region" required>
                    <option value="" disabled selected>(Region)</option>
                    <option value="South West">South West</option>
                    <option value="South East">South East</option>
                    <option value="London">London</option>
                    <option value="East Midlands">East Midlands</option>
                    <option value="West Midlands">West Midlands</option>
                    <option value="North East">North East</option>
                    <option value="North West">North West</option>
                    <option value="Scotland">Scotland</option>
                </select><br><br>
                <button type="submit" formaction="" class="w3-button">Submit</button>
            </form>
        </div>
        <br>
    
            <!--[if lt IE 7]>
             <p class="browsehappy">You are using an <strong>outdated</strong> browser. Please <a href="#">upgrade your browser</a> to improve your experience.</p>
            <![endif]-->
        <div align="center" style="position: relative; margin: auto;"><b>Honeywell NOC Horsham 2020</b></div>
        </body>
</html>      