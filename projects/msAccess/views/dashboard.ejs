        </head>
        <body>
            <ul>
                <% if (userLevel == 1) { %>
                <li><a href="/adm/userMgm"><i class="fa fa-users" aria-hidden="true"></i>User Management</a></li>
                <% } %>
                <li><a href="/"><i class="fa fa-sticky-note-o" aria-hidden="true"></i> Call Log Form</a></li>
                <li><a class="active" href="/dash"><i class="fa fa-bar-chart" aria-hidden="true"></i> Dashboard</a></li>
                <li><a href="/profile">My Profile</a></li>
                <li><a href="/signOut">Sign Out</a></li>
                <li style="float:right"><a href="/profile"><i class="fa fa-user-circle" aria-hidden="true"></i> <%= name %></a><li>
            </ul>
            <div class="dashboard">
                <div style="margin:auto;"><h1>NOC Stats Dashboard <%= monthn %></h1></div>
                <div class="inner-left">
                    <u>Year</u><br>2020<br><br>
                    <u>Month</u><br><br>
                    <a href="?month=1" class="w4-button">January</a>
                    <a href="?month=2" class="w4-button">February</a>
                    <a href="?month=3" class="w4-button">March</a>
                    <a href="?month=4" class="w4-button">April</a>
                    <a href="?month=5" class="w4-button">May</a>
                    <a href="?month=6" class="w4-button">June</a>
                    <a href="?month=7" class="w4-button">July</a>
                    <a href="?month=8" class="w4-button">August</a>
                    <a href="?month=9" class="w4-button">September</a>
                    <a href="?month=10" class="w4-button">October</a>
                    <a href="?month=11" class="w4-button">November</a>
                    <a href="?month=12" class="w4-button">December</a>
                    <a href="?month=13" class="w4-button">Year-To-Date</a>
                </div>
                <div class="inner-right">
                        <div class="row">
                            <div class="inner-inner">
                                <table style="width: 100%">
                                    <tr>
